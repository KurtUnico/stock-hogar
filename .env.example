# Copiá este archivo a .env (o .env.local) y completá con los datos de tu
# proyecto de Supabase: Project Settings -> API.
#
# VITE_SUPABASE_URL es la "Project URL".
# VITE_SUPABASE_ANON_KEY es la "anon public" key (NO la "service_role").
#
# Nunca subas el .env real a un repositorio. Vite solo expone al cliente las
# variables que empiezan con VITE_, así que estas dos son seguras de usar en
# el navegador (la anon key está pensada para eso, protegida por RLS).

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica
